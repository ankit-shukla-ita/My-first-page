import speech_recognition as sr
import pyttsx3

engine = pyttsx3.init()

def speak(text):
    print("Jarvis:", text)
    engine.say(text)
    engine.runAndWait()

def listen():
    r = sr.Recognizer()

    with sr.Microphone() as source:
        print("Boliye...")
        r.adjust_for_ambient_noise(source)
        audio = r.listen(source)

    try:
        command = r.recognize_google(audio, language="hi-IN")
        print("Aapne kaha:", command)
        return command.lower()

    except:
        speak("Mujhe samajh nahi aaya.")
        return ""

speak("Namaste, main Jarvis hoon.")

while True:
    command = listen()

    if "hello" in command:
        speak("Hello Ankit!")

    elif "time" in command or "samay" in command:
        from datetime import datetime
        now = datetime.now().strftime("%H:%M")
        speak(f"Abhi samay {now} hai.")

    elif "band ho jao" in command or "exit" in command:
        speak("Theek hai, bye.")
        break

    else:
        speak("Ye command abhi mujhe nahi aati.")
